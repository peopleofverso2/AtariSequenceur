# --- Serveur ---
PORT=8080

# --- Base de données ---
# Dev local (docker-compose) :
DATABASE_URL=postgres://postgres:postgres@localhost:5432/atari?sslmode=disable
# Cloud Run + Cloud SQL (socket Unix monté par --add-cloudsql-instances) :
# DATABASE_URL=postgres://atari:<password>@/atari?host=/cloudsql/<project>:<region>:<instance>

# --- Auth ---
# 256+ bits de hasard. Pour générer : openssl rand -base64 48
JWT_SECRET=replace-me-with-a-long-random-string

# --- Email (Brevo, optionnel) ---
# Sans ces variables, le partage de song renvoie un lien copiable au
# lieu d'envoyer un email automatique.
BREVO_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=STEP·SEQ
# URL publique de l'app — utilisée pour construire les liens d'invitation
APP_URL=http://localhost:8080
